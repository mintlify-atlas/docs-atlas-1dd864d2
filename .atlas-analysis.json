    "GET https://raw.githubusercontent.com/TannerTunstall/MapPipeline/main/kmls/mobilize-events.kml",
    "GET /kml-manifest.json",
    "scripts/update-kml.js — updateSafeAirspace()",
    "scripts/update-alerts.js — updateAlerts()",
    "scripts/update-mobilize.js — updateMobilizeEvents()",
